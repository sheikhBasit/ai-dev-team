# AI Dev Team - Environment Configuration
# Copy to .env and fill in your keys

# LLM Provider (pick one or both)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Default model
LLM_MODEL=claude-sonnet-4-20250514

# Max loop iterations before forcing human review
MAX_ITERATIONS=5

# Project directory to work on (override with --project flag)
DEFAULT_PROJECT_DIR=/home/basitdev/Villaex/VoiceAgentAPI

# SQLite checkpoint DB (for session persistence)
CHECKPOINT_DB=./checkpoints.db
