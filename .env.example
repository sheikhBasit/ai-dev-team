# ============================================================================
# AI Dev Team - Environment Configuration
# Copy to .env and fill in the keys you have
# ============================================================================

# ── LLM Model ───────────────────────────────────────────────────────────────
# The model to use. Provider is auto-detected from the model name.
# Override detection with LLM_PROVIDER if needed.
LLM_MODEL=claude-sonnet-4-20250514
# LLM_PROVIDER=anthropic          # explicit override (see list below)
# LLM_TEMPERATURE=0               # 0 = deterministic, 1 = creative
# LLM_MAX_TOKENS=8192

# Per-agent model overrides (optional — falls back to LLM_MODEL if unset)
# LLM_MODEL_CHEAP=claude-haiku-4-5-20251001   # fast/cheap agents use this
# AGENT_MODEL_CODER=claude-sonnet-4-6          # override specific agents
# AGENT_MODEL_ARCHITECT=claude-opus-4-7
# AGENT_MODEL_REVIEWER=claude-sonnet-4-6
# AGENT_MODEL_REQUIREMENTS=claude-haiku-4-5-20251001
# AGENT_MODEL_DESIGNER=claude-haiku-4-5-20251001
# AGENT_MODEL_EVALUATOR=claude-haiku-4-5-20251001
# AGENT_MODEL_TESTER=claude-sonnet-4-6
# AGENT_MODEL_SECURITY=claude-sonnet-4-6
# AGENT_MODEL_FRONTEND_WEB=claude-sonnet-4-6
# AGENT_MODEL_FRONTEND_MOBILE=claude-sonnet-4-6
# AGENT_MODEL_FRONTEND_DESKTOP=claude-sonnet-4-6
# AGENT_MODEL_AUDITOR=claude-sonnet-4-6

# ── Paid Providers (pick one or more) ───────────────────────────────────────

# Anthropic (Claude) — best for coding
# Models: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT)
# Models: gpt-4o, gpt-4o-mini, o1, o3-mini, o4-mini
# OPENAI_API_KEY=sk-your-key-here

# Google (Gemini) — pip install langchain-google-genai
# Models: gemini-2.0-flash, gemini-2.5-pro
# GOOGLE_API_KEY=your-key-here

# Mistral — pip install langchain-mistralai
# Models: mistral-large-latest, codestral-latest
# MISTRAL_API_KEY=your-key-here

# ── Free / Cheap Providers ──────────────────────────────────────────────────

# Groq (FREE, fast inference) — pip install langchain-groq
# Models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
# GROQ_API_KEY=gsk_your-key-here

# Together AI — pip install langchain-together
# Models: meta-llama/Llama-3.3-70B-Instruct-Turbo, deepseek-ai/DeepSeek-V3
# TOGETHER_API_KEY=your-key-here

# Fireworks AI — pip install langchain-fireworks
# Models: accounts/fireworks/models/llama-v3p3-70b-instruct
# FIREWORKS_API_KEY=your-key-here

# DeepSeek (cheap, good at code) — uses langchain-openai (already installed)
# Models: deepseek-chat, deepseek-coder
# DEEPSEEK_API_KEY=your-key-here

# HuggingFace — pip install langchain-huggingface
# Models: any model ID from huggingface.co
# HUGGINGFACEHUB_API_TOKEN=hf_your-token-here

# ── Local / Self-Hosted (FREE) ──────────────────────────────────────────────

# Ollama (local) — pip install langchain-ollama
# Run: ollama pull llama3.3 && ollama serve
# Set LLM_PROVIDER=ollama and LLM_MODEL=llama3.3
# OLLAMA_BASE_URL=http://localhost:11434

# Any OpenAI-compatible API (vLLM, LM Studio, LocalAI, etc.)
# Set LLM_PROVIDER=openai_compat
# OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPAT_API_KEY=not-needed

# ── Project Settings ────────────────────────────────────────────────────────
MAX_ITERATIONS=5
DEFAULT_PROJECT_DIR=/home/basitdev/Villaex/VoiceAgentAPI
CHECKPOINT_DB=./checkpoints.db

# Frontend target override — auto-detected from project files if unset
# Valid values: web | mobile | desktop | backend
# FRONTEND_TARGET=web

# ── Telegram Bot (optional) ────────────────────────────────────────────────
# Get from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your Telegram user ID (get from @userinfobot). Comma-separated for multiple.
# TELEGRAM_ALLOWED_USERS=123456789

# ── Langfuse Observability (optional) ─────────────────────────────────────
# Sign up at https://cloud.langfuse.com or self-host
# All agent LLM calls are traced automatically when these are set.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
